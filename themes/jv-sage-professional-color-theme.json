  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#546E6A", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "scope": ["constant.other.color", "constant.other.symbol"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "scope": ["keyword", "keyword.control", "keyword.operator.new", "keyword.operator.expression", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.logical"],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.class", "entity.other.inherited-class"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": { "foreground": "#d4ddd8" }
    },
    {
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": { "foreground": "#FFCB6B" }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": { "foreground": "#F07178" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#FFCB6B", "fontStyle": "italic" }
    },
    {
      "scope": ["support.type.property-name", "meta.object-literal.key"],
      "settings": { "foreground": "#A8D4C0" }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#8A9BA5" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#82AAFF", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#C3E88D" }
    },
    {
      "scope": ["meta.embedded", "source.groovy.embedded"],
      "settings": { "foreground": "#d4ddd8" }
    },
    {
      "scope": ["entity.name.section"],
      "settings": { "foreground": "#A8D4C0" }
    },
    {
      "scope": ["support.type", "support.variable"],
      "settings": { "foreground": "#89DDFF" }
    },
    {
      "scope": ["meta.decorator", "meta.decorator entity.name.function"],
      "settings": { "foreground": "#C792EA", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.name.module", "variable.import", "variable.other.readwrite.alias"],
      "settings": { "foreground": "#F07178" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#F07178" }
    }
  ]
}
